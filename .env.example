# Server
PORT=8001

# Supabase (project manager DB)
NEXT_PUBLIC_SUPABASE_URL=https://zqhdznwquejnkdpxsuui.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# RAG (document Q&A): management vector DB in same Supabase project
# Supabase Dashboard → Project Settings → Database → Connection string (URI). Use "Transaction" pooler or direct.
POSTGRES_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# OpenAI: used for RAG embeddings (text-embedding-ada-002) and answers (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Microsoft Graph / SharePoint (for pull-sharepoint and get-graph-token.js)
# From Azure App Registration: Overview → Application (client) ID, Directory (tenant) ID; Certificates & secrets → client secret
# SHAREPOINT_TENANT_ID=
# SHAREPOINT_CLIENT_ID=
# SHAREPOINT_CLIENT_SECRET=

# Optional: for pre-sharepoint check 6 (SharePoint idempotency)
# PROJECT_ID=<uuid>
# EMAIL=...
# PASSWORD=...
